{
  "layer": "top",
  "height": 32,
  "margin": "4",

  "modules-left": [
    "hyprland/workspaces",
    "tray",
  ],
  "modules-center": [
    "clock",
  ],
  "modules-right": [
    "idle_inhibitor",
    "custom/divider",
    "bluetooth",
    "custom/divider",
    "network",
    "custom/divider",
    "wireplumber",
    "custom/divider",
    "battery",
    "custom/power",
  ],
  
  
  "hyprland/workspaces": {
    "format": "{name}",
    "disable_scroll": true,
    "on-click": "activate",
    "sort-by-number": true,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
    },
  },

  "tray": {
    "spacing": 4,
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#DCD7BA'><b>{}</b></span>",
        "weekdays": "<span color='#DCD7BA'><b>{}</b></span>",
        "days": "<span color='#727169'><b>{}</b></span>",
        "today": "<span color='#FFA066'><b>{}</b></span>"
      },
    },
  },

  "custom/divider": {
		"format": "|",
		"tooltip": false,
  }, 

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "ΎΒχ ",
        "deactivated": "ΎΒ░ "
    },
  },

  "bluetooth": {
		"format": "ΎΛΥ",
    "format-off": "≤░Γ▓",
    "format-connected": "≤░Γ▒",
		"tooltip-format": "{controller_alias}\t{controller_address}",
		"tooltip-format-connected": "{controller_alias}\t\t{controller_address}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "rofi-bluetooth",
    "on-click-right": "$TERMINAL -e bluetuith"
	},

  "network": {
    "format-wifi" : "{icon}",
    "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
    "format-ethernet": "≤░ΙΑ",
    "format-alt" : "≤▒δΘ",
    "format-disconnected" : "≤░Ψς",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\t{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\t{ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
		"on-click": "wifimenu.sh",
    "on-click-right": "$TERMINAL -e nmtui"
	},  
  
  "wireplumber": {
		"format": "{volume}% {icon}",
		"format-muted": "{volume}% ≤░ζθ",
    "format-icons": {
      "headphones": "ΎΑξ",
      "handsfree": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
    },
		"format-icons": ["ΎΑο", "ΎΑπ", "ΎΑρ "],
    "on-click": "volume.sh mute",
		"on-click-right": "pavucontrol"
	},
  
  "battery": {
		"format": "{capacity}% {icon}",
    "format-icons": {
      "charging": [
        "≤░λθ",
        "≤░λε",
        "≤░ΓΗ",
        "≤░ΓΘ",
        "≤░ΓΙ",
        "≤░λζ",
        "≤░ΓΚ",
        "≤░λη",
        "≤░ΓΛ",
        "≤░ΓΜ",
        "≤░ΓΖ"
      ],
      "default": [
        "≤░ΓΟ",
        "≤░Β║",
        "≤░Β╝",
        "≤░Β╜",
        "≤░Β╛",
        "≤░Β┐",
        "≤░ΓΑ",
        "≤░ΓΒ",
        "≤░ΓΓ",
        "≤░Β╣",
      ],
    },
    "interval": 5,
		"on-click": ""
	}, 

  "custom/power": {
		"format": "<span font='13'>≤░Ρξ</span>",
		"on-click": "powermenu.sh",
		"tooltip": false
	}
}
