#! /usr/bin/bash

chosen=$(printf "яАС  Power Off\nяАЮ  Restart\nяЖЖ  Suspend\nяЛЬ  Hibernate\nяВЛ  Log Out\nяАг  Lock" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"яАС  Power Off") poweroff ;;
	"яАЮ  Restart") reboot ;;
	"яЖЖ  Suspend") systemctl suspend-then-hibernate ;;
	"яЛЬ  Hibernate") systemctl hibernate ;;
	"ябВ  Log Out") hyprctl dispatch exit ;;
	"яАг  Lock") hyprlock ;;
	*) exit 1 ;;
esac
